---
// About rhythm card renders one personal rhythm row with image and descriptive panel.
import type { RhythmItem } from '../../data/about';

interface Props {
	item: RhythmItem;
}

const { item } = Astro.props;
---

<article class="rhythm-card">
	<img src={item.image} alt={item.imageAlt} loading="lazy" />
	<div class={`rhythm-card__panel rhythm-card__panel--${item.theme}`}>
		<p class="rhythm-card__number">{item.number}</p>
		<p class="rhythm-card__text">{item.text}</p>
	</div>
</article>

<style>
	.rhythm-card {
		display: grid;
		grid-template-columns: 1fr;
		margin-bottom: 0.78rem;
	}

	.rhythm-card img {
		width: 100%;
		height: 100%;
		min-height: 250px;
		object-fit: cover;
	}

	.rhythm-card__panel {
		display: grid;
		align-content: center;
		justify-items: center;
		gap: 0.8rem;
		padding: clamp(1.3rem, 2.5vw, 2rem);
		text-align: center;
	}

	.rhythm-card__panel--light {
		background: #d9ccb0;
		color: var(--color-ink);
	}

	.rhythm-card__panel--dark {
		background: var(--color-olive-900);
		color: var(--color-cream-strong);
	}

	.rhythm-card__number {
		margin: 0;
		font-size: 0.64rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		opacity: 0.82;
	}

	.rhythm-card__text {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.28rem, 1.9vw, 1.6rem);
		line-height: 1.05;
		max-width: 24ch;
	}

	@media (min-width: 860px) {
		.rhythm-card {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
