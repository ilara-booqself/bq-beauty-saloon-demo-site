---
// Split content molecule renders a two-column image and content panel layout.
import TextBlock from '../atoms/TextBlock.astro';

interface Props {
	image: string;
	imageAlt: string;
	title: string;
	description: string;
	secondary?: string;
	reverse?: boolean;
	theme?: 'light' | 'dark';
}

const { image, imageAlt, title, description, secondary, reverse = false, theme = 'dark' } = Astro.props;
---

<article class={`split-card split-card--${theme} ${reverse ? 'split-card--reverse' : ''}`}>
	<img src={image} alt={imageAlt} loading="lazy" />
	<div class="split-card__content">
		<h3>{title}</h3>
		<TextBlock text={description} />
		{secondary && <TextBlock text={secondary} />}
	</div>
</article>

<style>
	.split-card {
		display: grid;
		grid-template-columns: 1fr;
	}

	.split-card img {
		width: 100%;
		height: 100%;
		min-height: 280px;
		object-fit: cover;
	}

	.split-card__content {
		display: grid;
		align-content: center;
		gap: 1rem;
		padding: clamp(1.6rem, 4vw, 3rem);
	}

	.split-card--dark .split-card__content {
		background: var(--color-olive-900);
		color: var(--color-cream-strong);
	}

	.split-card--dark :global(.text-block) {
		color: color-mix(in srgb, var(--color-cream-strong) 68%, #1a1a1a);
	}

	.split-card h3 {
		margin: 0;
		font-family: var(--font-display);
		font-weight: 500;
		font-size: clamp(1.8rem, 3.8vw, 3.1rem);
		line-height: 0.96;
	}

	@media (min-width: 840px) {
		.split-card {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.split-card--reverse img {
			order: 2;
		}
	}
</style>
