---
// Blog card molecule keeps article previews visually consistent in the guidance grid.
import type { BlogItem } from '../../data/landing';
import ButtonBase from '../atoms/ButtonBase.astro';

interface Props {
	item: BlogItem;
}

const { item } = Astro.props;
---

<article class="blog-card">
	<img src={item.image} alt={item.imageAlt} loading="lazy" />
	<div class="blog-card__content">
		<h3>{item.title}</h3>
		<p>{item.description}</p>
		<ButtonBase href={item.href} label="Read Article" variant="light" />
	</div>
</article>

<style>
	.blog-card {
		display: grid;
		gap: 0.9rem;
	}

	.blog-card img {
		width: 100%;
		height: 230px;
		object-fit: cover;
	}

	.blog-card__content {
		display: grid;
		gap: 0.8rem;
	}

	.blog-card h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.2rem;
		line-height: 1.2;
		font-weight: 600;
	}

	.blog-card p {
		margin: 0;
		font-size: 0.92rem;
		line-height: 1.6;
		color: var(--color-muted);
	}
</style>
