---
// Service tile molecule displays image and details with alternating light/dark panels.
import type { ServiceItem } from '../../data/landing';
import ButtonBase from '../atoms/ButtonBase.astro';

interface Props {
	service: ServiceItem;
	order: number;
}

const { service, order } = Astro.props;
---

<article class="service-tile">
	<img src={service.image} alt={service.imageAlt} loading="lazy" />
	<div class={`service-tile__panel service-tile__panel--${service.theme}`}>
		<p class="service-tile__id">{String(order).padStart(2, '0')}</p>
		<h3>{service.title}</h3>
		<p>{service.description}</p>
		<ButtonBase href={service.ctaHref} label={service.ctaLabel} variant={service.theme === 'dark' ? 'light' : 'dark'} />
	</div>
</article>

<style>
	.service-tile {
		display: grid;
		grid-template-columns: 1fr;
		margin-bottom: 0.78rem;
	}

	.service-tile img {
		width: 100%;
		height: 100%;
		min-height: 260px;
		object-fit: cover;
	}

	.service-tile__panel {
		display: grid;
		gap: 0.72rem;
		align-content: center;
		justify-items: start;
		padding: clamp(1.2rem, 2.5vw, 2.1rem);
	}

	.service-tile__panel--light {
		background: #d9ccb0;
		color: var(--color-ink);
	}

	.service-tile__panel--dark {
		background: var(--color-olive-900);
		color: var(--color-cream-strong);
	}

	.service-tile__id {
		margin: 0;
		font-size: 0.66rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		opacity: 0.8;
	}

	.service-tile h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.55rem, 2.1vw, 2.05rem);
		line-height: 1;
		font-weight: 500;
	}

	.service-tile p {
		margin: 0;
		font-size: 0.72rem;
		line-height: 1.55;
		max-width: 34ch;
	}

	@media (min-width: 840px) {
		.service-tile {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
