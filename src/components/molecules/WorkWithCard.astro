---
// Work-with card renders one offer preview with compact copy and CTA.
import type { WorkItem } from '../../data/about';
import ButtonBase from '../atoms/ButtonBase.astro';

interface Props {
	item: WorkItem;
}

const { item } = Astro.props;
---

<article class="work-card">
	<img src={item.image} alt={item.imageAlt} loading="lazy" />
	<div class="work-card__content">
		<h3>{item.title}</h3>
		<p>{item.description}</p>
		<ButtonBase href={item.ctaHref} label={item.ctaLabel} variant="light" />
	</div>
</article>

<style>
	.work-card {
		display: grid;
		gap: 0.8rem;
	}

	.work-card img {
		width: 100%;
		height: 130px;
		object-fit: cover;
	}

	.work-card__content {
		display: grid;
		gap: 0.6rem;
	}

	.work-card h3 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.2rem, 1.9vw, 1.42rem);
		line-height: 1.04;
	}

	.work-card p {
		margin: 0;
		font-size: 0.72rem;
		line-height: 1.5;
		color: var(--color-muted);
	}
</style>
