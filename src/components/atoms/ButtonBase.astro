---
// This button atom supports light and dark variants used throughout the landing page.
interface Props {
	href: string;
	label: string;
	variant?: 'dark' | 'light';
}

const { href, label, variant = 'dark' } = Astro.props;
---

<a class={`button button--${variant}`} href={href}>{label}</a>

<style>
	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.48rem 0.76rem;
		font-size: 0.5rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		border: 1px solid transparent;
		transition: transform 180ms ease, background-color 180ms ease, color 180ms ease;
	}

	.button:hover,
	.button:focus-visible {
		transform: translateY(-1px);
	}

	.button--dark {
		background: var(--color-button);
		color: var(--color-button-text);
	}

	.button--light {
		background: transparent;
		border-color: color-mix(in srgb, var(--color-ink) 35%, transparent);
		color: var(--color-ink);
	}
</style>
