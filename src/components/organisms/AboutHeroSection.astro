---
// About hero introduces Sally with image, primary positioning, and booking CTA.
import BookButton from '../atoms/BookButton.vue';

interface Props {
	label: string;
	title: string;
	description: string;
	image: string;
	imageAlt: string;
}

const { label, title, description, image, imageAlt } = Astro.props;
---

<section class="about-hero section-gap">
	<div class="container about-hero__inner">
		<img src={image} alt={imageAlt} fetchpriority="high" />
		<div class="about-hero__copy">
			<p class="small-label">{label}</p>
			<h1>{title}</h1>
			<p>{description}</p>
			<BookButton client:idle href="#book" />
		</div>
	</div>
</section>

<style>
	.about-hero {
		padding-block: clamp(1.2rem, 3vw, 2.2rem);
	}

	.about-hero__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.2rem;
	}

	.about-hero img {
		width: 100%;
		height: 100%;
		min-height: 240px;
		object-fit: cover;
	}

	.about-hero__copy {
		display: grid;
		align-content: center;
		gap: 0.78rem;
	}

	.about-hero__copy h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2rem, 3.3vw, 3rem);
		line-height: 0.95;
		font-weight: 500;
	}

	.about-hero__copy p {
		margin: 0;
		font-size: 0.75rem;
		line-height: 1.6;
		color: var(--color-muted);
		max-width: 45ch;
	}

	@media (min-width: 860px) {
		.about-hero__inner {
			grid-template-columns: minmax(0, 0.48fr) minmax(0, 0.52fr);
		}
	}
</style>
