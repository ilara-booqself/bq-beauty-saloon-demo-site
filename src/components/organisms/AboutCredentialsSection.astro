---
// Credentials section pairs credibility copy with a visual image block.
interface Props {
	label: string;
	title: string;
	copy: string;
	items: string[];
	image: string;
	imageAlt: string;
}

const { label, title, copy, items, image, imageAlt } = Astro.props;
---

<section class="about-credentials">
	<div class="container about-credentials__inner">
		<img src={image} alt={imageAlt} loading="lazy" />
		<div class="about-credentials__copy">
			<p class="small-label">{label}</p>
			<h2>{title}</h2>
			<p>{copy}</p>
			<ul>
				{items.map((item) => <li>{item}</li>)}
			</ul>
		</div>
	</div>
</section>

<style>
	.about-credentials {
		padding-block: clamp(2rem, 4vw, 3rem);
		background: var(--color-olive-900);
	}

	.about-credentials__inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.1rem;
	}

	.about-credentials img {
		width: 100%;
		height: 100%;
		min-height: 240px;
		object-fit: cover;
	}

	.about-credentials__copy {
		display: grid;
		align-content: center;
		gap: 0.7rem;
		color: var(--color-cream-strong);
	}

	.about-credentials__copy .small-label {
		color: color-mix(in srgb, var(--color-cream-strong) 74%, transparent);
	}

	.about-credentials h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.8rem, 2.5vw, 2.4rem);
		line-height: 0.98;
		font-weight: 500;
	}

	.about-credentials p {
		margin: 0;
		font-size: 0.74rem;
		line-height: 1.56;
		max-width: 46ch;
	}

	.about-credentials ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.34rem;
	}

	.about-credentials li {
		font-size: 0.72rem;
		line-height: 1.5;
	}

	.about-credentials li::before {
		content: '→ ';
	}

	@media (min-width: 860px) {
		.about-credentials__inner {
			grid-template-columns: minmax(0, 0.44fr) minmax(0, 0.56fr);
		}
	}
</style>
