---
// Testimonial organism reproduces the large curved dark panel for social proof.
interface Props {
	quote: string;
	author: string;
}

const { quote, author } = Astro.props;
---

<section id="client-love" class="testimonial">
	<div class="container testimonial__inner">
		<p class="small-label">Client Love</p>
		<blockquote>
			<p>{quote}</p>
			<cite>{author}</cite>
		</blockquote>
	</div>
</section>

<style>
	.testimonial {
		background: var(--color-olive-900);
		color: var(--color-cream-strong);
		border-bottom-left-radius: 100% 24%;
		border-bottom-right-radius: 100% 24%;
		padding-block: clamp(2.5rem, 6vw, 4.3rem);
	}

	.testimonial__inner {
		display: grid;
		gap: 1.2rem;
		justify-items: center;
	}

	.testimonial .small-label {
		color: color-mix(in srgb, var(--color-cream-strong) 70%, transparent);
	}

	.testimonial blockquote {
		margin: 0;
		text-align: center;
		max-width: 70ch;
		display: grid;
		gap: 1rem;
	}

	.testimonial p {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(1.35rem, 2.3vw, 2rem);
		line-height: 1.08;
		font-style: italic;
	}

	.testimonial cite {
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-style: normal;
		opacity: 0.8;
	}
</style>
