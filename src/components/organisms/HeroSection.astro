---
// Hero organism renders the large photo with arc line and centered title block.
import HeroTitleBlock from '../molecules/HeroTitleBlock.astro';

interface Props {
	image: string;
	imageAlt: string;
	title: string;
	description: string;
	ctaLabel: string;
	ctaHref: string;
}

const { image, imageAlt, title, description, ctaLabel, ctaHref } = Astro.props;
---

<section class="hero">
	<div class="hero__image-wrap">
		<img src={image} alt={imageAlt} fetchpriority="high" />
		<div class="hero__arc" aria-hidden="true"></div>
	</div>
	<div class="container hero__content section-gap">
		<HeroTitleBlock title={title} description={description} ctaLabel={ctaLabel} ctaHref={ctaHref} />
	</div>
</section>

<style>
	.hero__image-wrap {
		position: relative;
		height: clamp(240px, 48vw, 540px);
		overflow: hidden;
	}

	.hero__image-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero__arc {
		position: absolute;
		left: 50%;
		top: 52%;
		translate: -50% -50%;
		width: min(85vw, 1000px);
		height: min(85vw, 1000px);
		border-radius: 50%;
		border: 1px solid color-mix(in srgb, var(--color-cream) 74%, transparent);
		pointer-events: none;
	}

	.hero__content {
		padding-top: clamp(2rem, 4vw, 3.1rem);
		padding-bottom: clamp(2.3rem, 6vw, 3.7rem);
	}
</style>
